
$ kubectl -n build-room create serviceaccount ci-bot
serviceaccount/ci-bot created

$ kubectl -n build-room create role ci-bot --verb=get,list,watch,create,update,patch --resource=deployments.apps,configmaps
role.rbac.authorization.k8s.io/ci-bot created

$ kubectl -n build-room create rolebinding ci-bot --role=ci-bot --serviceaccount=build-room:ci-bot
rolebinding.rbac.authorization.k8s.io/ci-bot created

$ kubectl -n build-room describe role ci-bot
Name:         ci-bot
Labels:       <none>
Annotations:  <none>
PolicyRule:
  Resources         Non-Resource URLs  Resource Names  Verbs
  ---------         -----------------  --------------  -----
  configmaps        []                 []              [get list watch create update patch]
  deployments.apps  []                 []              [get list watch create update patch]

$ kubectl auth can-i create deployments -n build-room --as=system:serviceaccount:build-room:ci-bot
yes

$ kubectl auth can-i delete deployments -n build-room --as=system:serviceaccount:build-room:ci-bot || true
no

$ kubectl auth can-i create deployments -n default --as=system:serviceaccount:build-room:ci-bot || true
no

$ kubectl auth can-i get secrets -n build-room --as=system:serviceaccount:build-room:ci-bot || true
no

