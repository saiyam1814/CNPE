$ echo api-alpha > /Users/saiyam/cheapest.txt

$ echo api-gamma > /Users/saiyam/expensive.txt

$ kubectl -n alpha-svc scale deploy api-alpha --replicas=$(( $(kubectl -n alpha-svc get deploy api-alpha -o jsonpath='{.spec.replicas}') + 2 ))
deployment.apps/api-alpha scaled

$ kubectl -n gamma-svc scale deploy api-gamma --replicas=2
deployment.apps/api-gamma scaled

$ kubectl -n alpha-svc label deploy api-alpha cost.platform.io/adjusted=yes
deployment.apps/api-alpha labeled

$ kubectl -n gamma-svc label deploy api-gamma cost.platform.io/adjusted=yes
deployment.apps/api-gamma labeled

$ kubectl get deploy -A -l cost.platform.io/adjusted=yes
