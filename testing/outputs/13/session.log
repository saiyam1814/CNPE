$ kubectl wait --for=condition=established crd/featureflags.toggle.acme.dev --timeout=30s
customresourcedefinition.apiextensions.k8s.io/featureflags.toggle.acme.dev condition met

$ kubectl apply -f /Users/saiyam/checkout-express.yaml
featureflag.toggle.acme.dev/checkout-express created

$ kubectl get ff -n flags-lab
NAME               AGE
checkout-express   0s

$ kubectl apply -f bad-percent.yaml   # must FAIL (rolloutPercent 150)
The FeatureFlag "bad-percent" is invalid: spec.rolloutPercent: Invalid value: 150: spec.rolloutPercent in body should be less than or equal to 100
-> rejected (good)

$ kubectl apply -f no-enabled.yaml   # must FAIL (missing required field)
The FeatureFlag "no-enabled" is invalid: spec.enabled: Required value
-> rejected (good)

$ kubectl api-resources --api-group=toggle.acme.dev
NAME           SHORTNAMES   APIVERSION                NAMESPACED   KIND
