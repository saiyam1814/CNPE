$ cat /Users/saiyam/triage.txt
1. quota portal-quota caps pods at 1 - blocks metrics-ui pod creation
2. secret metrics-db-auth missing - metrics-db pod in CreateContainerConfigError
3. pvc metrics-ui-data missing - metrics-ui pod would stay Pending

$ kubectl apply -f portal-quota.yaml   # fix 1: loosen the quota
resourcequota/portal-quota configured

$ kubectl -n metrics-portal create secret generic metrics-db-auth --from-literal=POSTGRES_PASSWORD='s3cret-p0rtal'
secret/metrics-db-auth created

$ kubectl apply -f metrics-ui-data.yaml   # fix 3: the missing PVC
persistentvolumeclaim/metrics-ui-data created
waiting for both deployments (RS retry backoff can take ~1 min)...

$ kubectl -n metrics-portal wait --for=condition=available deploy --all --timeout=420s
